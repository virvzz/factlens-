{
  "name": "factlens-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Firefox WebExtension: fact-checking выделенного/вставленного текста через настраиваемый AI endpoint",
  "scripts": {
    "lint": "web-ext lint --source-dir extension",
    "test": "node --test \"tests/*.test.js\"",
    "build": "web-ext build --source-dir extension --artifacts-dir dist --overwrite-dest",
    "build:chrome": "node scripts/build-chrome.mjs",
    "icons": "node scripts/gen-icons.mjs",
    "zip": "npm run build"
  },
  "devDependencies": {
    "web-ext": "^8.9.0"
  }
}
